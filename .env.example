# openquote environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Anthropic API key (required for RFQ parsing)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set to "true" to use the in-memory mock backend (no real ERP needed)
OPENQUOTE_USE_MOCK=true

# AI model to use for parsing and quoting (default: claude-sonnet-4-6)
OPENQUOTE_MODEL=claude-sonnet-4-6

# --- Epicor Kinetic ---
OPENQUOTE_EPICOR_URL=https://your-epicor.company.com
OPENQUOTE_EPICOR_API_KEY=your_epicor_api_key_here
OPENQUOTE_EPICOR_COMPANY=EPIC

# --- SAP ECC / S/4HANA ---
OPENQUOTE_SAP_HOST=your-sap-host.company.com
OPENQUOTE_SAP_SYSNR=00
OPENQUOTE_SAP_CLIENT=100
OPENQUOTE_SAP_USER=your_sap_username
OPENQUOTE_SAP_PASSWORD=your_sap_password_here

# --- Oracle Cloud SCM ---
OPENQUOTE_ORACLE_BASE_URL=https://your-tenant.oraclecloud.com
OPENQUOTE_ORACLE_CLIENT_ID=your_oracle_client_id_here
OPENQUOTE_ORACLE_CLIENT_SECRET=your_oracle_client_secret_here

# --- Microsoft Dynamics 365 ---
OPENQUOTE_DYNAMICS_TENANT_ID=your_tenant_id_here
OPENQUOTE_DYNAMICS_CLIENT_ID=your_client_id_here
OPENQUOTE_DYNAMICS_CLIENT_SECRET=your_client_secret_here
OPENQUOTE_DYNAMICS_BASE_URL=https://your-org.api.crm.dynamics.com
